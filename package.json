{
    "name": "starter",
    "private": true,
    "packageManager": "pnpm@10.33.0",
    "scripts": {
        "create-site-configs-env": "dotenv -e .env.secrets -e .env.local -e .env -- pnpm exec comet inject-site-configs -f site-configs/site-configs.ts -i .env.site-configs.tpl -o .env.site-configs --base64",
        "dev": "dev-pm start",
        "dev:auth-proxy": "dotenv -- ./node_modules/.bin/oauth2-proxy --cookie-secret=$(head -c 16 /dev/random | base64)",
        "dev:auth-provider": "dotenv -- dev-oidc-provider",
        "setup-project-files": "node setup-project-files.js",
        "lint": "run-p -l lint:{admin,api,create-app,root,site}",
        "lint:admin": "pnpm --dir admin run lint",
        "lint:api": "pnpm --dir api run lint",
        "lint:ci": "pnpm run lint:root",
        "lint:create-app": "pnpm --dir api run lint",
        "lint:fix": "run-p -l lint:fix:{admin,api,root,site}",
        "lint:fix:admin": "pnpm --dir admin run lint:fix",
        "lint:fix:api": "pnpm --dir api run lint:fix",
        "lint:fix:root": "pnpm exec prettier --write './!(admin|api|site|create-app)/**/*.{js,json,md,yml,yaml}'",
        "lint:fix:site": "pnpm --dir site run lint:fix",
        "lint:knip": "run-p -l lint:knip:{admin,api,site}",
        "lint:knip:admin": "pnpm --dir admin run lint:knip",
        "lint:knip:api": "pnpm --dir api run lint:knip",
        "lint:knip:site": "pnpm --dir site run lint:knip",
        "lint:root": "pnpm exec prettier --check './!(admin|api|site|create-app)/**/*.{js,json,md,yml,yaml}'",
        "lint:site": "pnpm --dir site run lint",
        "test:ci": "run-p test:ci:*",
        "test:ci:api": "pnpm --dir api run test:ci",
        "build": "run-p build:*",
        "build:api": "pnpm --dir api run build",
        "build:admin": "pnpm --dir admin run build",
        "build:site": "pnpm --dir site run build",
        "prepare": "husky",
        "browser": "run-p browser:api browser:admin browser:site",
        "browser:api": "dotenv -- sh -c 'open-cli $API_URL/graphql'",
        "browser:admin": "dotenv -- sh -c 'open-cli $ADMIN_URL'",
        "browser:site": "dotenv -- sh -c 'open-cli $SITE_URL'",
        "browser:jaeger": "dotenv -- sh -c 'open-cli http://localhost:$JAEGER_UI_PORT'",
        "install-agent-skills": "pnpm exec comet install-agent-skills",
        "setup:ci": "pnpm run setup-project-files",
        "setup:download-oauth2-proxy": "dotenv -- sh -c 'pnpm exec comet download-oauth2-proxy -v $OAUTH2_PROXY_VERSION'"
    },
    "devDependencies": {
        "@comet/cli": "8.25.0",
        "@comet/dev-oidc-provider": "^1.2.1",
        "@comet/dev-process-manager": "^3.1.0",
        "dotenv-cli": "^11.0.0",
        "husky": "^9.1.7",
        "knip": "^6.24.0",
        "lint-staged": "^17.0.8",
        "npm-run-all2": "^9.0.2",
        "open-cli": "^9.0.0",
        "prettier": "^3.9.4",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": "24"
    }
}
